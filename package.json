{
  "name": "world-shaker",
  "version": "0.0.1",
  "private": true,
  "description": "World ID-gated AI dating MiniApp on World Network",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "db:gen-types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > types/db.gen.ts",
    "inngest:dev": "npx inngest-cli@latest dev"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.104.0",
    "@worldcoin/idkit": "^4.1.0",
    "@worldcoin/minikit-js": "^2.0.0",
    "inngest": "^4.2.0",
    "jose": "^5.10.0",
    "next": "^16.2.0",
    "openai": "^6.34.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "viem": "^2.48.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.0",
    "supabase": "^2.95.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
