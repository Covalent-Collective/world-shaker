# =====================================================
# World Shaker — Environment Variables
# Copy to .env.local and fill values. Never commit .env.local.
# =====================================================

# ----- World Developer Portal -----
# Get these from https://developer.worldcoin.org → your app
NEXT_PUBLIC_WORLD_APP_ID=app_staging_xxxxxxxxxxxx
WORLD_RP_ID=rp_xxxxxxxxxxxx
# CRITICAL: Server-only. Never expose to client. Used to sign rp_context.
WORLD_SIGNING_KEY=

# Action name — fixed at deployment, used to scope nullifiers.
# Same value across staging and production. Changing it = all users get new nullifiers.
NEXT_PUBLIC_WORLD_ACTION=create-profile

# 'staging' during development, 'production' for live.
NEXT_PUBLIC_WORLD_ENVIRONMENT=staging

# Developer Portal API key (server-side calls to verify endpoint, payment status)
WORLD_DEV_PORTAL_API_KEY=

# ----- Supabase -----
# Public — safe to expose to client
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxx

# Service role — SERVER ONLY. Bypasses RLS. Used by Inngest jobs and admin routes.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxx

# JWT signing secret. MUST match Supabase project's JWT secret (Settings → API → JWT Secret)
# so that the JWT we issue after orb verify is accepted by Supabase RLS via auth.jwt().
SUPABASE_JWT_SECRET=

# Required for supabase CLI migrations and npm run db:gen-types.
# Find it in Supabase Dashboard → Project Settings → General → Reference ID.
SUPABASE_PROJECT_ID=xxxxxxxxxxxxxxxx
SUPABASE_DB_PASSWORD=

# ----- LLM Gateway (OpenRouter) -----
# Single API key — chat (Anthropic Sonnet) + embeddings (OpenAI) routed through OpenRouter.
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx

# Optional model overrides (default values match the spec — swap without code change)
# OPENROUTER_CHAT_MODEL=anthropic/claude-sonnet-4.6
# OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Optional: image model for avatar generation (Phase 3).
# If unset, lib/avatar/generate.ts falls back to a deterministic placeholder set
# keyed on hash of extracted_features — no generation API call is made.
# Set this before Phase 3 kickoff if real avatars are required at launch.
# OPENROUTER_IMAGE_MODEL=

# ----- World App Push (Phase 4) -----
# Controls daily-digest (morning) and mutual-match impact-only push notifications.
# Set false until World App push SDK stability is confirmed — falls back to in-app badge.
WORLD_APP_PUSH_ENABLED=false

# Production push endpoint. Only read when WORLD_APP_PUSH_ENABLED=true.
# Leave blank in local dev (in-app badge fallback activates automatically).
WORLD_APP_PUSH_URL=

# ----- Inngest -----
# Get from inngest dashboard → app → keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ----- PostHog (analytics + session replay + LLM analytics) -----
# Get from https://app.posthog.com/project/settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Optional: separate API key for server-side capture (defaults to public key if unset)
POSTHOG_PROJECT_API_KEY=

# Note: Endpoint protection (Arcjet/Upstash ratelimit) intentionally omitted in v0.
# Multi-layer defense covers v0 abuse vectors:
#   - World ID orb proof + Dev Portal v4 verify (real human gate)
#   - DB UNIQUE (nullifier, action) (one-account-per-human)
#   - auth_nonces with consumed_at (replay protection)
#   - RLS via current_world_user_id() JWT claim (data isolation)
#   - Column-level GRANT on matches (mutation scope)
# Reconsider when traffic justifies it.

# ----- App config -----
# The hosted URL — used in deep links. Vercel default is fine.
NEXT_PUBLIC_APP_URL=https://world-shaker.vercel.app

# Slack webhook for T&S alerts (P2)
SLACK_WEBHOOK_TS_ALERTS=

# ----- Cost-cap alert (Phase 4) -----
# Optional: Slack webhook URL for daily LLM cost-cap breach notifications.
# When app_settings.streaming_paused flips true (global cap exceeded), an alert
# is posted here. If unset, the alert is logged server-side only — no Slack message sent.
SLACK_WEBHOOK_URL=

# ----- Feature flags -----
# Controls EN prompt rendering. Default false = KR-only prompts at launch.
# Flip to true ONLY after the EN rubric passes (Phase 5.5 gate):
#   - npm run eval:en-prompts → 2 human raters → aggregate ≥ 7/10, no dim < 5
# Until the gate passes, this must stay false in production.
# Staging may set true for EN rubric evaluation runs.
BILINGUAL_PROMPTS_V1=false
