# =====================================================
# World Shaker — Environment Variables
# Copy to .env.local and fill values. Never commit .env.local.
# =====================================================

# ----- World Developer Portal -----
# Get these from https://developer.worldcoin.org → your app
NEXT_PUBLIC_WORLD_APP_ID=app_staging_xxxxxxxxxxxx
WORLD_RP_ID=rp_xxxxxxxxxxxx
# CRITICAL: Server-only. Never expose to client. Used to sign rp_context.
WORLD_SIGNING_KEY=

# Action name — fixed at deployment, used to scope nullifiers.
# Same value across staging and production. Changing it = all users get new nullifiers.
NEXT_PUBLIC_WORLD_ACTION=create-profile

# 'staging' during development, 'production' for live.
NEXT_PUBLIC_WORLD_ENVIRONMENT=staging

# Developer Portal API key (server-side calls to verify endpoint, payment status)
WORLD_DEV_PORTAL_API_KEY=

# ----- Supabase -----
# Public — safe to expose to client
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxx

# Service role — SERVER ONLY. Bypasses RLS. Used by Inngest jobs and admin routes.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxx

# JWT signing secret. MUST match Supabase project's JWT secret (Settings → API → JWT Secret)
# so that the JWT we issue after orb verify is accepted by Supabase RLS via auth.jwt().
SUPABASE_JWT_SECRET=

# For supabase CLI / migrations
SUPABASE_PROJECT_ID=xxxxxxxxxxxxxxxx
SUPABASE_DB_PASSWORD=

# ----- LLM Gateway (OpenRouter) -----
# Single API key — chat (Anthropic Sonnet) + embeddings (OpenAI) routed through OpenRouter.
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx

# Optional model overrides (default values match the spec — swap without code change)
# OPENROUTER_CHAT_MODEL=anthropic/claude-sonnet-4.6
# OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# ----- Inngest -----
# Get from inngest dashboard → app → keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ----- Sentry (optional, P2) -----
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ----- PostHog (optional, P2) -----
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ----- App config -----
# The hosted URL — used in deep links. Vercel default is fine.
NEXT_PUBLIC_APP_URL=https://world-shaker.vercel.app

# Slack webhook for T&S alerts (P2)
SLACK_WEBHOOK_TS_ALERTS=
